# ordio MCP Server — environment variables
# Copy this file to .env and fill in your values

# Required: Clerk API key used as Bearer token for all ordio API requests
# Get this from: https://dashboard.clerk.com → API Keys → Secret key
ORDIO_API_KEY=sk_live_...

# Required: Organization ID to scope all tool calls
# Find this in the ordio app URL: getordio.com/org_xxxxxxxxxx/...
ORDIO_ORG_ID=org_xxxxxxxxxx

# Optional: Override the API base URL (defaults to https://api.getordio.com)
# ORDIO_API_BASE_URL=https://api.getordio.com
